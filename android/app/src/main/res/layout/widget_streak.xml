<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_streak_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_background"
  android:orientation="vertical"
  android:gravity="center"
  android:paddingLeft="@dimen/widget_padding_horizontal"
  android:paddingRight="@dimen/widget_padding_horizontal"
  android:paddingTop="@dimen/widget_padding_vertical"
  android:paddingBottom="@dimen/widget_padding_vertical"
>

    <!-- HERO SECTION (Flame + Count) -->
    <LinearLayout
    android:id="@+id/widget_streak_hero_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp"
  >

        <!-- Generative Flame directly on the background (No circle container) -->
        <ImageView
      android:id="@+id/widget_streak_icon"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:src="@drawable/ic_pixel_flame_active"
      android:scaleType="fitCenter"
    />

        <!-- Count & Label Stack -->
        <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:layout_marginStart="16dp"
    >

            <TextView
        android:id="@+id/widget_streak_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:singleLine="true"
        android:text="0"
        android:textColor="@color/widget_text_primary"
        android:textSize="42sp"
        android:includeFontPadding="false"
        android:layout_marginBottom="-4dp"
      />

            <TextView
        android:id="@+id/widget_streak_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="DAY STREAK"
        android:textColor="@color/widget_text_label"
        android:textSize="10sp"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
      />
        </LinearLayout>
    </LinearLayout>

    <!-- DATA LAYER (Pixel Heatmap) -->
    <LinearLayout
    android:id="@+id/widget_streak_heatmap_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="8dp"
    android:visibility="gone"
  >

        <!-- Pixels -->
        <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_horizontal"
    >
            <ImageView
        android:id="@+id/widget_streak_day_1"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/widget_pixel_inactive"
        android:layout_marginRight="4dp"
      />
            <ImageView
        android:id="@+id/widget_streak_day_2"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/widget_pixel_inactive"
        android:layout_marginRight="4dp"
      />
            <ImageView
        android:id="@+id/widget_streak_day_3"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/widget_pixel_inactive"
        android:layout_marginRight="4dp"
      />
            <ImageView
        android:id="@+id/widget_streak_day_4"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/widget_pixel_inactive"
        android:layout_marginRight="4dp"
      />
            <ImageView
        android:id="@+id/widget_streak_day_5"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/widget_pixel_inactive"
        android:layout_marginRight="4dp"
      />
            <ImageView
        android:id="@+id/widget_streak_day_6"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/widget_pixel_inactive"
        android:layout_marginRight="4dp"
      />
            <ImageView
        android:id="@+id/widget_streak_day_7"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/widget_pixel_inactive"
      />
        </LinearLayout>

        <!-- Labels -->
        <LinearLayout
      android:id="@+id/widget_streak_day_labels"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center"
      android:layout_marginTop="6dp"
    >
            
            <!-- Using fixed width elements for exact alignment with the 16dp+4dp squares -->
            <!-- 16dp block + 4dp margin = 20dp space per item. 16dp center. -->
            <TextView
        android:id="@+id/widget_streak_label_1"
        android:layout_width="16dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="M"
        android:textColor="@color/widget_text_label"
        android:textSize="10sp"
        android:layout_marginRight="4dp"
      />
            <TextView
        android:id="@+id/widget_streak_label_2"
        android:layout_width="16dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="T"
        android:textColor="@color/widget_text_label"
        android:textSize="10sp"
        android:layout_marginRight="4dp"
      />
            <TextView
        android:id="@+id/widget_streak_label_3"
        android:layout_width="16dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="W"
        android:textColor="@color/widget_text_label"
        android:textSize="10sp"
        android:layout_marginRight="4dp"
      />
            <TextView
        android:id="@+id/widget_streak_label_4"
        android:layout_width="16dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="T"
        android:textColor="@color/widget_text_label"
        android:textSize="10sp"
        android:layout_marginRight="4dp"
      />
            <TextView
        android:id="@+id/widget_streak_label_5"
        android:layout_width="16dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="F"
        android:textColor="@color/widget_text_label"
        android:textSize="10sp"
        android:layout_marginRight="4dp"
      />
            <TextView
        android:id="@+id/widget_streak_label_6"
        android:layout_width="16dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="S"
        android:textColor="@color/widget_text_label"
        android:textSize="10sp"
        android:layout_marginRight="4dp"
      />
            <TextView
        android:id="@+id/widget_streak_label_7"
        android:layout_width="16dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="S"
        android:textColor="@color/widget_text_label"
        android:textSize="10sp"
      />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
