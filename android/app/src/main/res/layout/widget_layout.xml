<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_accent_card"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:paddingLeft="@dimen/widget_padding_horizontal"
    android:paddingRight="@dimen/widget_padding_horizontal"
    android:paddingTop="@dimen/widget_padding_vertical"
    android:paddingBottom="@dimen/widget_padding_vertical">

    <!-- HEADER: Label and Add button -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/widget_gap_xs">

        <TextView
            android:id="@+id/widget_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SPENDING BALANCE"
            android:textColor="#B3FFFFFF"
            android:textSize="@dimen/widget_text_label"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:textAllCaps="true" />

        <ImageView
            android:id="@+id/widget_add_btn"
            android:layout_width="@dimen/widget_btn_size"
            android:layout_height="@dimen/widget_btn_size"
            android:background="@drawable/widget_pill_bg"
            android:src="@drawable/ic_add_white"
            android:padding="@dimen/widget_btn_padding"
            android:contentDescription="Add Transaction" />
    </LinearLayout>

    <!-- MAIN AMOUNT -->
    <TextView
        android:id="@+id/widget_total_spent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹0"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/widget_text_amount"
        android:fontFamily="serif"
        android:includeFontPadding="false" />

    <!-- PROGRESS BAR: Thin line style from app -->
    <FrameLayout
        android:id="@+id/widget_progress_container"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="@dimen/widget_gap_md">

        <ImageView
            android:id="@+id/widget_progress_fill"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:visibility="gone" />
    </FrameLayout>

    <!-- SPENT LABEL -->
    <TextView
        android:id="@+id/widget_spent_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/widget_gap_sm"
        android:text="spent this month"
        android:textColor="#CCFFFFFF"
        android:textSize="@dimen/widget_text_label"
        android:fontFamily="sans-serif" />

    <!-- CONTENT CONTAINER: Categories and Transactions (Shown on larger sizes) -->
    <LinearLayout
        android:id="@+id/widget_content_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <!-- CATEGORIES -->
        <LinearLayout
            android:id="@+id/widget_categories_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <!-- (Logic from previous design but simplified for accent card) -->
            <TextView android:id="@+id/widget_cat_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#B3FFFFFF" android:textSize="@dimen/widget_text_category" android:layout_marginBottom="@dimen/widget_gap_xs" />
            <TextView android:id="@+id/widget_cat_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#B3FFFFFF" android:textSize="@dimen/widget_text_category" />
        </LinearLayout>

        <!-- TRANSACTIONS -->
        <LinearLayout
            android:id="@+id/widget_transactions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/widget_gap_sm"
            android:visibility="gone">
            <TextView android:id="@+id/widget_tx_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#99FFFFFF" android:textSize="@dimen/widget_text_tx" android:singleLine="true" android:layout_marginBottom="@dimen/widget_gap_xs" />
            <TextView android:id="@+id/widget_tx_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#99FFFFFF" android:textSize="@dimen/widget_text_tx" android:singleLine="true" android:layout_marginBottom="@dimen/widget_gap_xs" />
            <TextView android:id="@+id/widget_tx_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#99FFFFFF" android:textSize="@dimen/widget_text_tx" android:singleLine="true" android:layout_marginBottom="@dimen/widget_gap_xs" />
            <TextView android:id="@+id/widget_tx_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#99FFFFFF" android:textSize="@dimen/widget_text_tx" android:singleLine="true" android:layout_marginBottom="@dimen/widget_gap_xs" />
            <TextView android:id="@+id/widget_tx_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#99FFFFFF" android:textSize="@dimen/widget_text_tx" android:singleLine="true" android:layout_marginBottom="@dimen/widget_gap_xs" />
            <TextView android:id="@+id/widget_tx_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#99FFFFFF" android:textSize="@dimen/widget_text_tx" android:singleLine="true" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
