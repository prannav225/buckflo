<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:paddingLeft="24dp"
    android:paddingRight="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:id="@+id/widget_root">

    <!-- Top Right: Add Button (Primary Action) -->
    <ImageView
        android:id="@+id/widget_add_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:background="@drawable/widget_btn_bg"
        android:src="@drawable/ic_add_white"
        android:padding="10dp"/>

    <!-- Top Left: Header and Total Spent -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true"
        android:layout_alignParentLeft="true"
        android:layout_toLeftOf="@id/widget_add_btn"
        android:layout_marginRight="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THIS MONTH"
            android:textColor="#88ffffff"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:letterSpacing="0.1" />
        <TextView
            android:id="@+id/widget_total_spent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0"
            android:textColor="#ffffff"
            android:textSize="36sp"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:layout_marginTop="0dp"/>
    </LinearLayout>

    <!-- Content Area spans fully below the header row -->
    <LinearLayout
        android:id="@+id/widget_content_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_below="@id/widget_header"
        android:layout_marginTop="16dp"
        android:clipChildren="true">

        <!-- Top Categories Row -->
        <LinearLayout
            android:id="@+id/widget_categories_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">
            <TextView
                android:id="@+id/widget_cat_1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginRight="6dp"
                android:background="@drawable/widget_pill_bg"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="13sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:text="Food"/>
            <TextView
                android:id="@+id/widget_cat_2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:background="@drawable/widget_pill_bg"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="13sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:text="Transport"/>
        </LinearLayout>

        <!-- Recent Transactions List (Auto-fills available space) -->
        <LinearLayout
            android:id="@+id/widget_transactions_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECENT"
                android:textColor="#88ffffff"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp"/>
                
            <TextView android:id="@+id/widget_tx_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="15sp" android:paddingBottom="10dp" android:text="" android:fontFamily="sans-serif" android:singleLine="true"/>
            <TextView android:id="@+id/widget_tx_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="15sp" android:paddingBottom="10dp" android:text="" android:fontFamily="sans-serif" android:singleLine="true"/>
            <TextView android:id="@+id/widget_tx_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="15sp" android:paddingBottom="10dp" android:text="" android:fontFamily="sans-serif" android:singleLine="true"/>
            <TextView android:id="@+id/widget_tx_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="15sp" android:paddingBottom="10dp" android:text="" android:fontFamily="sans-serif" android:singleLine="true"/>
            <TextView android:id="@+id/widget_tx_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="15sp" android:paddingBottom="10dp" android:text="" android:fontFamily="sans-serif" android:singleLine="true"/>
            <TextView android:id="@+id/widget_tx_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="15sp" android:paddingBottom="10dp" android:text="" android:fontFamily="sans-serif" android:singleLine="true"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
