<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/widget_corner_radius" />
            <solid android:color="@color/widget_border" />
        </shape>
    </item>
    <!-- Card Surface -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <solid android:color="@color/widget_bg_start" />
        </shape>
    </item>
</layer-list>
