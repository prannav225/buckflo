<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow/Edge -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#26000000" />
        </shape>
    </item>
    <!-- Main Button -->
    <item android:bottom="2dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="@color/widget_accent"
                android:endColor="@color/widget_accent_end"
                android:angle="270" />
        </shape>
    </item>
    <!-- Top Shine -->
    <item android:bottom="2dp" android:left="4dp" android:right="4dp" android:top="2dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
