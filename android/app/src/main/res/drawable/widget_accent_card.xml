<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Card Body -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/widget_corner_radius" />
            <gradient
                android:startColor="#E67E5D"
                android:endColor="#D97757"
                android:angle="270" />
        </shape>
    </item>
    <!-- Subtle Inner Glow/Grain effect (Simulated with thin light border) -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
        </shape>
    </item>
</layer-list>
